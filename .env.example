# -----------------------------------------------------------------------------
# Auth service (JWT issuer) + MCP — required for `npm run dev` and `npm run oauth-agent`
# See your welcome email for log in details for the admin portal. These values can be found in the admin portal.
# -----------------------------------------------------------------------------
AUTH_BASE_URL=https://...

# Streamable MCP URL (must end with /mcp). Used by `npm run dev` and `npm run oauth-agent`.
MCP_ENDPOINT=https://...

# After creating an agent in admin (or after a one-time bootstrap), keep these on the automation host:
CLIENT_ID=
CLIENT_SECRET=

# Optional: one-time first run when id/secret are not in .env yet (then copy them from the bootstrap response).
BOOTSTRAP_TOKEN=

# -----------------------------------------------------------------------------
# Web chat (`npm run dev` / `npm start`)
# -----------------------------------------------------------------------------
PUBLIC_SITE_URL=http://localhost:3847
PORT=3847
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
